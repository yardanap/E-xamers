                   </item>
                   <item>
                    <widget class="QPushButton" name="btn_reset_stats">
                     <property name="minimumSize"><size><width>150</width><height>40</height></size></property>
                     <property name="font"><font><family>Cambria</family><pointsize>12</pointsize><bold>true</bold></font></property>
                     <property name="styleSheet"><string notr="true">QPushButton { background-color: #e74c3c; color: white; border-radius: 20px; } QPushButton:hover { background-color: #c0392b; }</string></property>
                     <property name="text"><string>Reset Stats</string></property>
                    </widget>
                   </item>
                   <item>
                    <widget class="QPushButton" name="btn_export_stats">
                     <property name="minimumSize"><size><width>150</width><height>40</height></size></property>
                     <property name="font"><font><family>Cambria</family><pointsize>12</pointsize><bold>true</bold></font></property>
                     <property name="styleSheet"><string notr="true">QPushButton { background-color: black; color: white; border-radius: 20px; } QPushButton:hover { background-color: #333333; }</string></property>
                     <property name="text"><string>Export to CSV</string></property>
                    </widget>
                   </item>
                  </layout>
                 </item>
                </layout>
               </widget>
              </item>
             </layout>
            </widget>

           </widget>
          </item>
         </layout>
        </item>
       </layout>
      </widget>

      <!-- PAGE 3: EXAM ENGINE -->
      <widget class="QWidget" name="page_exam">
       <property name="styleSheet"><string notr="true">QWidget#page_exam { background-color: #ffffff; }</string></property>
       <layout class="QVBoxLayout" name="verticalLayout_exam">
        <property name="spacing"><number>0</number></property>
        <property name="margin"><number>0</number></property>
        
        <!-- TOP BAR EXAM -->
        <item>
         <widget class="QFrame" name="exam_topbar">
          <property name="minimumSize"><size><width>0</width><height>60</height></size></property>
          <property name="styleSheet"><string notr="true">QFrame#exam_topbar { background-color: #2c3e50; }</string></property>
          <layout class="QHBoxLayout" name="horizontalLayout_topbar">
           <item><widget class="QLabel" name="exam_mode_label"><property name="font"><font><family>Cambria</family><pointsize>16</pointsize><bold>true</bold></font></property><property name="styleSheet"><string notr="true">color: white;</string></property><property name="text"><string>Mode: -</string></property></widget></item>
           <item>
            <spacer name="horizontalSpacer_topbar">
             <property name="orientation"><enum>Qt::Orientation::Horizontal</enum></property>
             <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
            </spacer>
           </item>
           <item><widget class="QLabel" name="exam_timer_label"><property name="font"><font><family>Cambria</family><pointsize>18</pointsize><bold>true</bold></font></property><property name="styleSheet"><string notr="true">color: #e74c3c;</string></property><property name="text"><string>00:00:00</string></property></widget></item>
          </layout>
         </widget>
        </item>

        <!-- EXAM CONTENT (LEFT & RIGHT) -->
        <item>
         <layout class="QHBoxLayout" name="horizontalLayout_exam_content">
          <property name="spacing"><number>10</number></property>
          <property name="margin"><number>10</number></property>
          
          <!-- LEFT PANEL (QUESTIONS) -->
          <item>
           <widget class="QScrollArea" name="scrollArea_question">
            <property name="widgetResizable"><bool>true</bool></property>
            <property name="styleSheet"><string notr="true">QScrollArea { border: none; background-color: #ffffff; }</string></property>
            <widget class="QWidget" name="scrollAreaWidgetContents">
             <property name="geometry"><rect><x>0</x><y>0</y><width>800</width><height>600</height></rect></property>
             <property name="styleSheet"><string notr="true">QWidget#scrollAreaWidgetContents { background-color: #ffffff; }</string></property>
             <layout class="QVBoxLayout" name="verticalLayout_q_content">
              <property name="spacing"><number>20</number></property>
              
              <!-- Teks Soal -->
              <item><widget class="QLabel" name="exam_question_text"><property name="font"><font><family>Cambria</family><pointsize>14</pointsize></font></property><property name="styleSheet"><string notr="true">color: black;</string></property><property name="text"><string>Teks Soal Muncul Di Sini...</string></property><property name="wordWrap"><bool>true</bool></property></widget></item>
              
              <!-- Gambar Soal -->
              <item><widget class="QLabel" name="exam_question_image"><property name="styleSheet"><string notr="true">background-color: transparent;</string></property><property name="text"><string/></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>
              
              <!-- Pilihan Ganda -->
              <item>
               <layout class="QVBoxLayout" name="verticalLayout_options">
                <property name="spacing"><number>15</number></property>
                <item><widget class="QRadioButton" name="radio_A"><property name="font"><font><family>Cambria</family><pointsize>13</pointsize></font></property><property name="styleSheet"><string notr="true">color: black;</string></property><property name="text"><string>A. </string></property></widget></item>
                <item><widget class="QRadioButton" name="radio_B"><property name="font"><font><family>Cambria</family><pointsize>13</pointsize></font></property><property name="styleSheet"><string notr="true">color: black;</string></property><property name="text"><string>B. </string></property></widget></item>
                <item><widget class="QRadioButton" name="radio_C"><property name="font"><font><family>Cambria</family><pointsize>13</pointsize></font></property><property name="styleSheet"><string notr="true">color: black;</string></property><property name="text"><string>C. </string></property></widget></item>
                <item><widget class="QRadioButton" name="radio_D"><property name="font"><font><family>Cambria</family><pointsize>13</pointsize></font></property><property name="styleSheet"><string notr="true">color: black;</string></property><property name="text"><string>D. </string></property></widget></item>
                <item><widget class="QRadioButton" name="radio_E"><property name="font"><font><family>Cambria</family><pointsize>13</pointsize></font></property><property name="styleSheet"><string notr="true">color: black;</string></property><property name="text"><string>E. </string></property></widget></item>
               </layout>
              </item>

              <!-- EVALUASI FRAME -->
              <item>
               <widget class="QFrame" name="frame_evaluation">
                <property name="styleSheet"><string notr="true">QFrame#frame_evaluation { background-color: #f8f9fa; border: 1px solid #dee2e6; border-radius: 10px; }</string></property>
                <layout class="QVBoxLayout" name="verticalLayout_eval">
                 <item><widget class="QLabel" name="eval_result_label"><property name="font"><font><family>Cambria</family><pointsize>16</pointsize><bold>true</bold></font></property><property name="styleSheet"><string notr="true">color: black;</string></property><property name="text"><string>Incorrect!</string></property></widget></item>
                 <item>
                  <layout class="QHBoxLayout" name="horizontalLayout_eval_class">
                   <item><widget class="QLabel" name="label_error_class"><property name="font"><font><family>Cambria</family><pointsize>12</pointsize></font></property><property name="styleSheet"><string notr="true">color: black;</string></property><property name="text"><string>Classifying Error:</string></property></widget></item>
                   <item>
                    <widget class="QComboBox" name="combo_error_class">
                     <property name="minimumSize"><size><width>200</width><height>35</height></size></property>
                     <property name="font"><font><family>Cambria</family><pointsize>12</pointsize></font></property>
                     <property name="styleSheet"><string notr="true">color: black; background-color: white; border: 1px solid gray;</string></property>
                     <item><property name="text"><string>Knowledge Gap</string></property></item>
                     <item><property name="text"><string>Guessing</string></property></item>
                     <item><property name="text"><string>Misread</string></property></item>
                     <item><property name="text"><string>Accident Click</string></property></item>
                    </widget>
                   </item>
                   <item>
                    <spacer name="horizontalSpacer_eval">
                     <property name="orientation"><enum>Qt::Orientation::Horizontal</enum></property>
                     <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
                    </spacer>
                   </item>
                  </layout>
                 </item>
                 <item><widget class="QLabel" name="eval_explanation_text"><property name="font"><font><family>Cambria</family><pointsize>12</pointsize></font></property><property name="styleSheet"><string notr="true">color: black;</string></property><property name="text"><string>Explanation text goes here...</string></property><property name="wordWrap"><bool>true</bool></property></widget></item>
                </layout>
               </widget>
              </item>
              
              <item>
               <spacer name="verticalSpacer_q">
                <property name="orientation"><enum>Qt::Orientation::Vertical</enum></property>
                <property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property>
               </spacer>
              </item>
             </layout>
            </widget>
           </widget>
          </item>

          <!-- RIGHT PANEL (QUESTION GRID) -->
          <item>
           <widget class="QFrame" name="frame_question_grid">
            <property name="minimumSize"><size><width>280</width><height>0</height></size></property>
            <property name="maximumSize"><size><width>280</width><height>16777215</height></size></property>
            <property name="styleSheet"><string notr="true">QFrame#frame_question_grid { background-color: #f4f6f9; border-left: 2px solid #e0e0e0; }</string></property>
            <layout class="QVBoxLayout" name="verticalLayout_grid">
             <item><widget class="QLabel" name="label_grid_title"><property name="font"><font><family>Cambria</family><pointsize>14</pointsize><bold>true</bold></font></property><property name="styleSheet"><string notr="true">color: black;</string></property><property name="text"><string>Daftar Soal</string></property></widget></item>
             <item>
              <widget class="QScrollArea" name="scrollArea_grid">
               <property name="widgetResizable"><bool>true</bool></property>
               <property name="styleSheet"><string notr="true">QScrollArea { border: none; background-color: transparent; }</string></property>
               <widget class="QWidget" name="scrollAreaGridContents">
                <property name="geometry"><rect><x>0</x><y>0</y><width>250</width><height>500</height></rect></property>
                <layout class="QGridLayout" name="gridLayout_question_numbers"/>
               </widget>
              </widget>
             </item>
            </layout>
           </widget>
          </item>
         </layout>
        </item>

        <!-- BOTTOM BAR -->
        <item>
         <widget class="QFrame" name="exam_bottombar">
          <property name="minimumSize"><size><width>0</width><height>70</height></size></property>
          <property name="styleSheet"><string notr="true">QFrame#exam_bottombar { background-color: #ecf0f1; border-top: 2px solid #bdc3c7; }</string></property>
          <layout class="QHBoxLayout" name="horizontalLayout_bottombar">
           <property name="spacing"><number>15</number></property>
           <property name="leftMargin"><number>20</number></property>
           <property name="rightMargin"><number>20</number></property>
           <item><widget class="QPushButton" name="btn_exam_prev"><property name="minimumSize"><size><width>120</width><height>40</height></size></property><property name="font"><font><family>Cambria</family><pointsize>12</pointsize><bold>true</bold></font></property><property name="styleSheet"><string notr="true">QPushButton { background-color: #95a5a6; color: white; border-radius: 5px; }</string></property><property name="text"><string>Previous</string></property></widget></item>
           <item><widget class="QPushButton" name="btn_exam_flag"><property name="minimumSize"><size><width>120</width><height>40</height></size></property><property name="font"><font><family>Cambria</family><pointsize>12</pointsize><bold>true</bold></font></property><property name="styleSheet"><string notr="true">QPushButton { background-color: #f39c12; color: white; border-radius: 5px; }</string></property><property name="text"><string>Flag (Ragu)</string></property></widget></item>
           <item>
            <spacer name="horizontalSpacer_bottombar">
             <property name="orientation"><enum>Qt::Orientation::Horizontal</enum></property>
             <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
            </spacer>
           </item>
           <item><widget class="QPushButton" name="btn_exam_next"><property name="minimumSize"><size><width>120</width><height>40</height></size></property><property name="font"><font><family>Cambria</family><pointsize>12</pointsize><bold>true</bold></font></property><property name="styleSheet"><string notr="true">QPushButton { background-color: #3498db; color: white; border-radius: 5px; }</string></property><property name="text"><string>Next</string></property></widget></item>
           <item><widget class="QPushButton" name="btn_exam_finish"><property name="minimumSize"><size><width>120</width><height>40</height></size></property><property name="font"><font><family>Cambria</family><pointsize>12</pointsize><bold>true</bold></font></property><property name="styleSheet"><string notr="true">QPushButton { background-color: #e74c3c; color: white; border-radius: 5px; }</string></property><property name="text"><string>Finish Test</string></property></widget></item>
          </layout>
         </widget>
        </item>

       </layout>
      </widget>

     </widget>
    </item>
   </layout>
  </widget>

  <!-- REPORT FRAME (FLOATING OVERLAY) -->
  <widget class="QFrame" name="report_frame">
   <property name="geometry"><rect><x>340</x><y>100</y><width>600</width><height>500</height></rect></property>
   <property name="styleSheet"><string notr="true">QFrame#report_frame { background-color: white; border: 2px solid black; border-radius: 20px; }</string></property>
   <layout class="QVBoxLayout" name="v_report">
    <item>
     <layout class="QHBoxLayout" name="h_report_top">
      <item><widget class="QLabel" name="report_title"><property name="text"><string>STATISTIK PENGERJAAN</string></property><property name="styleSheet"><string notr="true">font-size: 20px; font-weight: bold; color: black;</string></property></widget></item>
      <item><widget class="QPushButton" name="btn_close_report"><property name="text"><string>X</string></property><property name="minimumSize"><size><width>30</width><height>30</height></size></property><property name="styleSheet"><string notr="true">background: #e74c3c; color: white; border-radius: 15px; font-weight: bold;</string></property></widget></item>
     </layout>
    </item>
    <item><widget class="QLabel" name="report_score_label"><property name="text"><string>Skor: -</string></property><property name="styleSheet"><string notr="true">font-size: 18px; color: black; font-weight: bold;</string></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>
    <item><widget class="QLabel" name="report_time_label"><property name="text"><string>Waktu Dihabiskan: 00:00:00</string></property><property name="styleSheet"><string notr="true">font-size: 16px; color: #2980b9; font-weight: bold;</string></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>
    <item>
     <widget class="QScrollArea" name="scroll_report">
      <property name="widgetResizable"><bool>true</bool></property>
      <property name="styleSheet"><string notr="true">QScrollArea { border: none; background-color: white; }</string></property>
      <widget class="QWidget" name="scroll_report_content">
       <property name="styleSheet"><string notr="true">QWidget#scroll_report_content { background-color: white; }</string></property>
       <layout class="QVBoxLayout" name="v_report_scroll">
        <item><widget class="QLabel" name="report_topic_summary"><property name="text"><string>Rincian Topik Salah:</string></property><property name="styleSheet"><string notr="true">color: black; font-weight: bold;</string></property></widget></item>
        <item><widget class="QLabel" name="report_topic_details"><property name="styleSheet"><string notr="true">color: black;</string></property><property name="wordWrap"><bool>true</bool></property></widget></item>
        <item><widget class="QLabel" name="report_error_summary"><property name="text"><string>Proporsi Kesalahan:</string></property><property name="styleSheet"><string notr="true">color: black; font-weight: bold; margin-top: 10px;</string></property></widget></item>
        <item><widget class="QLabel" name="report_error_details"><property name="styleSheet"><string notr="true">color: black;</string></property><property name="wordWrap"><bool>true</bool></property></widget></item>
        <item>
         <spacer name="v_sp_report">
          <property name="orientation"><enum>Qt::Orientation::Vertical</enum></property>
          <property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property>
         </spacer>
        </item>
       </layout>
      </widget>
     </widget>
    </item>
   </layout>
  </widget>

  <!-- POPUP FRAME -->
  <widget class="QFrame" name="popup_frame">
   <property name="geometry"><rect><x>515</x><y>600</y><width>250</width><height>50</height></rect></property>
   <property name="styleSheet"><string notr="true">QFrame#popup_frame { background-color: white; border-radius: 15px; border: 1px solid black; } QLabel { color: black; font-size: 14px; font-weight: bold; }</string></property>
   <layout class="QVBoxLayout" name="verticalLayout"><item><widget class="QLabel" name="popup_label"><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item></layout>
  </widget>
